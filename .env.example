services:
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: app-frontend
    ports:
      - "5173:5173"
    env_file:
      - .env.example
    depends_on:
      - backend

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: app-backend
    ports:
      - "5000:5000"
    env_file:
      - .env.example
    depends_on:
      - postgres

  postgres:
    image: postgres:16
    container_name: app-postgres
    restart: unless-stopped
    ports:
      - "5432:5432"
    env_file:
      - .env.example
    volumes:
      - postgres_data:/var/lib/postgresql/data

  judge0-server:
    image: judge0/judge0:1.13.1
    container_name: judge0-server
    restart: unless-stopped
    ports:
      - "2358:2358"
    env_file:
      - .env.example

  openwebui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: openwebui
    restart: unless-stopped
    ports:
      - "8080:8080"
    env_file:
      - .env.example

volumes:
  postgres_data: