# ---------- App ----------
NODE_ENV=development

# ---------- Frontend (Vite dev only; not used by Docker frontend build) ----------
# Leave unset or empty when using `npm run dev` — vite.config.js proxies /api → :5000.
# Set only if you want the browser to call backend on another host:
# VITE_API_BASE_URL=http://localhost:5000

# ---------- Backend ----------
PORT=5000
JWT_SECRET=changeme

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

# ---------- Ollama (AI) ----------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_VALIDATOR_MODEL=qwen2.5:3b-instruct
OLLAMA_PORT=11434

# ---------- Judge0 ----------
JUDGE0_URL=http://host.docker.internal:2358
# Max wait per submission (ms). Stops backend hanging if Judge0/isolate stalls.
JUDGE0_REQUEST_TIMEOUT_MS=90000

# ---------- Open WebUI ----------
WEBUI_SECRET_KEY=changeme-openwebui-secret
OPEN_WEBUI_PORT=8080
