# HOW TO USE
# ----------
# 1. Copy this file:  cp .env.example .env
# 2. Fill in all values marked CHANGE THIS
# 3. Start the stack:  docker compose up -d
#
# The .env file is gitignored — never commit it with real secrets.
# =========================
# App
# =========================
NODE_ENV=development

# =========================
# Frontend (Vite dev only)
# Leave blank when running inside Docker — nginx proxies /api automatically.
# Set to http://localhost:5000 only when running the frontend outside Docker.
# =========================
VITE_API_BASE_URL=http://34.7.32.253:5000

# =========================
# Backend
# =========================
PORT=5000

# Access token secret — CHANGE THIS in production (min 32 random chars)
JWT_SECRET=changeme-jwt-secret

# Refresh token secret — must be DIFFERENT from JWT_SECRET
REFRESH_SECRET=changeme-refresh-secret

# Comma-separated allowed CORS origins (production/staging use)
# Example: FRONTEND_ORIGIN=https://app.yourdomain.com
FRONTEND_ORIGIN=http://34.7.32.253

# =========================
# Database
# =========================
# Docker-internal hostname — backend container connects to postgres container
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/app_db

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

# =========================
# Ollama (AI)
# Docker-internal URL — backend talks to the Ollama container
# =========================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434

# Primary model: AI Mentor chat + problem variation generation
# Pull with: docker exec -it ollama ollama pull qwen2.5-coder:14b
OLLAMA_MODEL=qwen2.5-coder:14b

# Validator model: safety-checks AI replies before delivery to students
# Smaller/faster is fine here; falls back to heuristics on failure
# Pull with: docker exec -it ollama ollama pull qwen2.5:3b-instruct
OLLAMA_VALIDATOR_MODEL=qwen2.5:3b-instruct

# =========================
# Judge0 (Code execution)
# =========================
# Backend in Docker, Judge0 on host machine:
JUDGE0_URL=http://host.docker.internal:2358

# Max time (ms) to wait for Judge0 before timing out
JUDGE0_REQUEST_TIMEOUT_MS=90000

# =========================
# Open WebUI
# =========================
OPENWEBUI_URL=http://openwebui:8080
WEBUI_SECRET_KEY=changeme-openwebui-secret
OPEN_WEBUI_PORT=8080
