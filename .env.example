# =========================
# App
# =========================
NODE_ENV=development

# =========================
# Frontend
# =========================
VITE_API_BASE_URL=http://localhost:5000
VITE_DEMO_EMAIL=student1@demo.com
VITE_DEMO_PASSWORD=123456

# =========================
# Backend
# =========================
PORT=5000
JWT_SECRET=changeme

# Backend container içinden servis adresleri
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/app_db
OPENWEBUI_URL=http://openwebui:8080
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=ai-mentor
# Judge0 API (default server port 2358).
# - Backend on host, Judge0 on host: http://localhost:2358
# - Backend in Docker (this compose), Judge0 on host: http://host.docker.internal:2358
#   (`extra_hosts` is set on the backend service for Linux-compatible host access.)
# - Backend and Judge0 both in Docker on the same network: http://<judge0-service>:2358
JUDGE0_URL=http://host.docker.internal:2358

# =========================
# PostgreSQL (app database)
# =========================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

# =========================
# Open WebUI
# =========================
WEBUI_SECRET_KEY=changeme-openwebui-secret
OPEN_WEBUI_PORT=8080

# =========================
# Ollama
# =========================
OLLAMA_PORT=11434