generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AttemptMode {
  raw
  tests
}

enum NormalizedStatus {
  accepted
  wrong_answer
  syntax_error
  runtime_error
  time_limit_exceeded
  memory_limit_exceeded
  compile_error
  internal_error
}

enum PolicyAction {
  allow
  rewrite
  fallback_safe_hint
  block
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique

  users User[]
}

model User {
  id                  Int                    @id @default(autoincrement())
  name                String
  email               String                 @unique
  passwordHash        String
  roleId              Int
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  role                Role                   @relation(fields: [roleId], references: [id])
  problems            Problem[]
  submissions         Submission[]
  aiLogs              AiLog[]
  submissionAttempts  SubmissionAttempt[]
  hintEvents          HintEvent[]
  aiInteractionAudits AIInteractionAudit[]
  createdAssignments  Assignment[]           @relation("CreatedAssignments")
  enrollments         AssignmentEnrollment[]
  grades              Grade[]                @relation("GradedBy")
  createdVariations   ProblemVariation[]     @relation("CreatedVariations")
  createdGroups       StudentGroup[]          @relation("CreatedGroups")
  groupMemberships    StudentGroupMembership[]
}

model Problem {
  id                  Int                  @id @default(autoincrement())
  title               String
  description         String
  starterCode         String?
  referenceSolution   String?
  difficulty          String?
  language            String               @default("javascript")
  tags                String[]             @default([])
  category            String?
  metadata            Json?
  createdById         Int
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  createdBy           User                   @relation(fields: [createdById], references: [id])
  testCases           TestCase[]
  submissions         Submission[]
  aiLogs              AiLog[]
  submissionAttempts  SubmissionAttempt[]
  hintEvents          HintEvent[]
  aiInteractionAudits AIInteractionAudit[]
  assignments         Assignment[]
  rubrics             Rubric[]
  variations          ProblemVariation[]
}

model TestCase {
  id             Int      @id @default(autoincrement())
  problemId      Int
  input          String
  expectedOutput String
  isHidden       Boolean  @default(false)
  createdAt      DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Submission {
  id            Int      @id @default(autoincrement())
  userId        Int
  problemId     Int
  code          String
  language      String   @default("javascript")
  status        String
  stdout        String?
  stderr        String?
  executionTime Float?
  memory        Int?
  createdAt     DateTime @default(now())

  user     User                @relation(fields: [userId], references: [id])
  problem  Problem             @relation(fields: [problemId], references: [id])
  aiLogs   AiLog[]
  attempts SubmissionAttempt[]
}

model SubmissionAttempt {
  id                 Int                  @id @default(autoincrement())
  userId             Int
  problemId          Int?
  submissionId       Int?
  mode               AttemptMode
  language           String
  sourceCode         String
  judge0Status       String?
  normalizedStatus   NormalizedStatus
  publicPassed       Int?
  publicTotal        Int?
  hiddenPassed       Int?
  hiddenTotal        Int?
  allPassed          Boolean?
  stdout             String?
  stderr             String?
  compileOutput      String?
  executionTimeMs    Float?
  memoryKb           Int?
  createdAt          DateTime             @default(now())

  user               User                 @relation(fields: [userId], references: [id])
  problem            Problem?             @relation(fields: [problemId], references: [id])
  submission         Submission?          @relation(fields: [submissionId], references: [id])
  hintEvents         HintEvent[]
  aiInteractionAudits AIInteractionAudit[]

  @@index([userId, problemId, createdAt])
  @@index([problemId, createdAt])
}

model HintEvent {
  id        Int      @id @default(autoincrement())
  userId    Int
  problemId Int
  attemptId Int?
  aiLogId   Int?
  sequence  Int      @default(1)
  mode      String   @default("hint")
  createdAt DateTime @default(now())

  user    User               @relation(fields: [userId], references: [id])
  problem Problem            @relation(fields: [problemId], references: [id])
  attempt SubmissionAttempt?  @relation(fields: [attemptId], references: [id])
  aiLog   AiLog?             @relation(fields: [aiLogId], references: [id])

  @@index([userId, problemId, createdAt])
  @@index([problemId, createdAt])
}

model AiLog {
  id              Int      @id @default(autoincrement())
  userId          Int
  problemId       Int
  submissionId    Int?
  mode            String   @default("practice")
  promptVersion   String
  modelName       String
  studentQuestion String?
  responseText    String
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  problem    Problem     @relation(fields: [problemId], references: [id])
  submission Submission? @relation(fields: [submissionId], references: [id])
  hintEvents HintEvent[]
}

model AIInteractionAudit {
  id                 Int                @id @default(autoincrement())
  userId             Int
  problemId          Int
  attemptId          Int?
  mentorModel        String
  validatorModel     String?
  mentorRaw          String
  validatorJson      Json?
  policyAction       PolicyAction
  finalText          String
  rewriteCount       Int                @default(0)
  latencyMsMentor    Int?
  latencyMsValidator Int?
  errorCode          String?
  createdAt          DateTime           @default(now())

  user               User               @relation(fields: [userId], references: [id])
  problem            Problem            @relation(fields: [problemId], references: [id])
  attempt            SubmissionAttempt?  @relation(fields: [attemptId], references: [id])

  @@index([userId, problemId, createdAt])
  @@index([problemId, createdAt])
}

model SystemFlag {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

// ── Assignment ────────────────────────────────────────────────────────────────
// A teacher creates an assignment that links a problem to a deadline/instructions.

model Assignment {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  problemId    Int
  createdById  Int
  dueDate          DateTime?
  isPublished      Boolean   @default(false)
  allowedLanguages String[]  @default([])
  lateDeadline     DateTime?
  lateDeduction    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt    DateTime @updatedAt

  problem     Problem                @relation(fields: [problemId], references: [id])
  createdBy   User                   @relation("CreatedAssignments", fields: [createdById], references: [id])
  enrollments AssignmentEnrollment[]
  grades      Grade[]

  @@index([createdById])
  @@index([problemId])
}

// ── AssignmentEnrollment ──────────────────────────────────────────────────────
// Tracks which students are enrolled in which assignment.

model AssignmentEnrollment {
  id           Int      @id @default(autoincrement())
  assignmentId Int
  userId       Int
  enrolledAt   DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([assignmentId, userId])
  @@index([userId])
}

// ── Rubric ────────────────────────────────────────────────────────────────────
// AI-suggested or teacher-written grading rubric for a problem.

model Rubric {
  id          Int      @id @default(autoincrement())
  problemId   Int
  title       String   @default("Default Rubric")
  /// JSON array of { criterion: string, maxPoints: number, description: string }
  criteria    Json
  totalPoints Int      @default(100)
  aiGenerated Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  grades  Grade[]

  @@index([problemId])
}

// ── Grade ─────────────────────────────────────────────────────────────────────
// Final grade given to a student for an assignment submission.

model Grade {
  id           Int      @id @default(autoincrement())
  assignmentId Int
  userId       Int
  rubricId     Int?
  score        Float
  maxScore     Float    @default(100)
  /// JSON array of { criterion: string, points: number, comment: string }
  breakdown    Json?
  feedback     String?
  aiSuggested  Boolean  @default(false)
  gradedById   Int
  gradedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  user       User       @relation("GradedBy", fields: [gradedById], references: [id])
  rubric     Rubric?    @relation(fields: [rubricId], references: [id])

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
}

// ── ProblemVariation ──────────────────────────────────────────────────────────
// AI-generated similar/variant problem; teacher reviews before publishing.

enum VariationStatus {
  pending
  approved
  rejected
}

model ProblemVariation {
  id              Int             @id @default(autoincrement())
  sourceProblemId Int
  createdById     Int
  title           String
  description     String
  starterCode     String?
  difficulty      String?
  language        String
  status          VariationStatus @default(pending)
  aiModel         String?
  promptVersion   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  sourceProblem Problem @relation(fields: [sourceProblemId], references: [id])
  createdBy     User    @relation("CreatedVariations", fields: [createdById], references: [id])

  @@index([sourceProblemId])
  @@index([createdById])
}

// ── StudentGroup ──────────────────────────────────────────────────────────────
model StudentGroup {
  id          Int      @id @default(autoincrement())
  name        String
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User                    @relation("CreatedGroups", fields: [createdById], references: [id])
  members     StudentGroupMembership[]

  @@index([createdById])
}

model StudentGroupMembership {
  id      Int @id @default(autoincrement())
  groupId Int
  userId  Int

  group StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}
